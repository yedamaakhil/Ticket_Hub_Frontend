PORT=8080

# Email (SMTP) — configure for real delivery
# Gmail example: smtp.gmail.com, port 587, use an App Password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="TicketHub" <noreply@tickethub.com>

# Razorpay (optional — mock mode works without these)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
